# Copy this file to .env and fill in the values.
# For production: replace "localhost" with the server IP or domain.
# Example: http://200.135.X.X  or  https://academia.ufsm.br

# Public URL of the frontend, used in password recovery emails.
# Dev:  http://localhost
# Prod: http://IP-DO-SERVIDOR
FRONTEND_URL=http://localhost

# Allowed CORS origins for the backend API.
# Must match FRONTEND_URL.
# Dev:  http://localhost
# Prod: http://IP-DO-SERVIDOR
CORS_ORIGINS=http://localhost

# PostgreSQL password.
# Dev:  any value works
# Prod: generate with: openssl rand -base64 32
POSTGRES_PASSWORD=beeai_dev_local
